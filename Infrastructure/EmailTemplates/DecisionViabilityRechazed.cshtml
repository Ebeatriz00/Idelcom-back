@inherits RazorLight.TemplatePage<Core.Entities.Email.DecisionViabilityRechazed>
@{
    Layout = "TemplateEmail";
}

@section Title {
        Viabilidad Rechazada
}

<p style="margin:0 0 14px; font-size:15px;">
    Hola, @Model.ReceiverName
</p>

<p style="margin:0 0 18px; font-size:14px; line-height:1.6; color:#444;">
    Se informa que la viabilidad para la siguiente oportunidad ha sido <b>RECHAZADA</b> dentro del sistema <b>IDELCOM ERP</b>.
</p>

<table width="100%" cellspacing="0" cellpadding="0"
       style="background:#F7F9FC; border:1px solid #E6ECF5; border-radius:10px; padding:16px;">
    <tr>
        <td style="font-size:13px; color:#0D4C9C; font-weight:700; padding-bottom:10px;">
            Resumen de la Oportunidad
        </td>
    </tr>
    <tr>
        <td>
            <table width="100%" cellspacing="0" cellpadding="0">
                <tr>
                    <td style="font-size:14px; color:#555; width:140px; padding:6px 0;">
                        <b>N&deg; Oportunidad:</b>
                    </td>
                    <td style="font-size:14px; padding:6px 0;">
                        @Model.OpporNumber
                    </td>
                </tr>

                <tr>
                    <td style="font-size:14px; color:#555; padding:6px 0; vertical-align: top;">
                        <b>Descripci&oacute;n:</b>
                    </td>
                    <td style="font-size:14px; padding:6px 0;">
                        @Model.OpporName
                    </td>
                </tr>

                <tr>
                    <td style="font-size:14px; color:#555; padding:6px 0;">
                        <b>Cliente:</b>
                    </td>
                    <td style="font-size:14px; padding:6px 0;">
                        @Model.ClientsName
                    </td>
                </tr>

                <tr>
                    <td style="font-size:14px; color:#555; padding:6px 0;">
                        <b>Nuevo Estado:</b>
                    </td>
                    <td style="font-size:14px; padding:6px 0;">
                        @Model.StatusGeneral
                    </td>
                </tr>
                <tr>
                    <td style="font-size:14px; color:#555; padding:6px 0;">
                        <b>Etapa Comercial:</b>
                    </td>
                    <td style="font-size:14px; padding:6px 0;">
                        @Model.StatusOppor
                    </td>
                </tr>
                <tr>
                    <td style="font-size:14px; color:#555; padding:6px 0; vertical-align: top;">
                        <b>Motivo Rechazo:</b>
                    </td>
                    <td style="font-size:14px; padding:6px 0;">
                        @Model.RejectionReason
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>

<p style="margin:18px 0 0; font-size:14px; color:#444;">
    La oportunidad ha sido archivada. Por favor revisa tu bandeja para más detalles.
</p>
