@inherits RazorLight.TemplatePage<Core.Entities.Email.OpporStateChangedDeliverables>
@{
    Layout = "TemplateEmail";
}

@section Title {
            Nuevos entregables de preventa
}

<p style="margin:0 0 20px; font-size:15px;">
    Estimado <b style="color:#0D4C9C;">@Model.ReceiverName</b>,
</p>

<p style="margin:0 0 28px; font-size:14px; line-height:1.65; color:#444;">
    Se han registrado <b>nuevos entregables de preventa</b> asociados a la siguiente
    oportunidad comercial en el sistema <b>IDELCOM ERP</b>. A continuación se detalla
    la información de la oportunidad y los entregables solicitados.
</p>

<!-- Info Box -->
<table width="100%" cellspacing="0" cellpadding="0"
       style="background:#F7F9FC; border:1px solid #E1E8F0; border-radius:10px; padding:18px;">

    <tr>
        <td style="font-size:13px; color:#0D4C9C; font-weight:700; padding-bottom:12px;">
            Información de la Oportunidad
        </td>
    </tr>

    <tr>
        <td>
            <table width="100%" cellpadding="0" cellspacing="0">

                <tr>
                    <td style="font-size:14px; width:160px; padding:6px 0; color:#555;"><b>N° Oportunidad:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.OpporNumber</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Descripción:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.OpporName</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Cliente:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.ClientsName</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Vendedor:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.SellerName</td>
                </tr>
                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Estado General:</b></td>
                    <td style="font-size:14px; padding:6px 0; color:#0D4C9C; font-weight:600;">@Model.StatusGeneral</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Etapa Comercial:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.StatusOppor</td>
                </tr>
                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Etapa Preventa:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.StatusOpporSales</td>
                </tr>

            </table>
        </td>
    </tr>
</table>

<p style="margin:0 0 10px; font-size:14px; font-weight:600; color:#0D4C9C;">
    Nuevos entregables registrados
</p>

<table width="100%" cellspacing="0" cellpadding="0"
       style="border-collapse:collapse; font-size:13px; margin-bottom:8px;">
    <thead>
        <tr>
            <th align="left" style="padding:8px; border-bottom:1px solid #E1E8F0;">Entregable</th>
            <th align="left" style="padding:8px; border-bottom:1px solid #E1E8F0;">Estado</th>
            <th align="left" style="padding:8px; border-bottom:1px solid #E1E8F0;">Fecha compromiso</th>
            <th align="left" style="padding:8px; border-bottom:1px solid #E1E8F0;">Comentario</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.DeliverablesSales != null && Model.DeliverablesSales.Count > 0)
        {
            foreach (var d in Model.DeliverablesSales)
            {
                <tr>
                    <td style="padding:8px; border-bottom:1px solid #F0F3F7;">
                        @d.DeliverablesName
                    </td>
                    <td style="padding:8px; border-bottom:1px solid #F0F3F7;">
                        @(string.IsNullOrWhiteSpace(d.State) ? "-" : d.State)
                    </td>
                    <td style="padding:8px; border-bottom:1px solid #F0F3F7;">
                        @(d.DueDate.HasValue? d.DueDate.Value.ToString("dd/MM/yyyy") : "-")
                    </td>
                    <td style="padding:8px; border-bottom:1px solid #F0F3F7;">
                        @(string.IsNullOrWhiteSpace(d.Comment) ? "-" : d.Comment)
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="4" style="padding:10px; font-style:italic; color:#777;">
                    No se encontraron entregables asociados en este cambio.
                </td>
            </tr>
        }
    </tbody>
</table>

<p style="margin:18px 0 0; font-size:14px; line-height:1.6; color:#444;">
    Agradeceremos su revisi&oacute;n y coordinaci&oacute;n con el equipo  para la gesti&oacute;n de estos entregables.
</p>