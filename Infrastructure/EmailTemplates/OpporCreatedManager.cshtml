@inherits RazorLight.TemplatePage<Core.Entities.Email.OpporCreated>
@{
    Layout = "TemplateEmail";
}

@section Title {
       Nueva Oportunidad Comercial
}

<p style="margin:0 0 20px; font-size:15px;">
    Estimado <b style="color:#0D4C9C;">@Model.ReceiverName</b>,
</p>

<p style="margin:0 0 28px; font-size:14px; line-height:1.65; color:#444;">
    Se ha registrado una nueva oportunidad por parte de la Gerencia Comercial, la cual pasa
    directamente a la etapa de <b>Preventa</b> para su análisis y atención. A continuación se
    detalla la información principal del registro para iniciar la gestión correspondiente.
</p>

<!-- Info Box -->
<table width="100%" cellspacing="0" cellpadding="0"
       style="background:#F7F9FC; border:1px solid #E1E8F0; border-radius:10px; padding:18px;">

    <tr>
        <td style="font-size:13px; color:#0D4C9C; font-weight:700; padding-bottom:12px;">
            Informaci&oacute;n de la Oportunidad
        </td>
    </tr>

    <tr>
        <td>
            <table width="100%" cellpadding="0" cellspacing="0">

                <tr>
                    <td style="font-size:14px; width:160px; padding:6px 0; color:#555;"><b>N° Oportunidad:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.OpporNumber</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Descripci&oacute;n:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.OpporName</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Cliente:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.ClientsName</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Vendedor:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.SellerName</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Sector:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.SectorName</td>
                </tr>
                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Viabilidad:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.Viability%</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Estado General:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.StatusGeneral</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Etapa Comercial:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.StatusOppor</td>
                </tr>
                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Etapa Preventa:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.StatusOpporSales</td>
                </tr>
                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>Fecha Cierre:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.DateFinish</td>
                </tr>

            </table>
        </td>
    </tr>
</table>

<p style="margin:18px 0 0; font-size:14px; line-height:1.6; color:#444;">
    Agradeceremos su revisi&oacute;n y coordinaci&oacute;n con el equipo  para la gesti&oacute;n correspondiente.
</p>