@inherits RazorLight.TemplatePage<Core.Entities.Email.QuotationInvalidated>
@{
    Layout = "TemplateEmail";
}

@section Title {
            Alerta: Cotización Anulada
}

<p style="margin:0 0 20px; font-size:15px;">
    Hola <b style="color:#0D4C9C;">@Model.WorkerName</b>,
</p>

<p style="margin:0 0 28px; font-size:14px; line-height:1.65; color:#444;">
    El sistema <b>IDELCOM ERP</b> le informa que la cotización vigente ha sido <b>ANULADA AUTOMÁTICAMENTE</b> debido a una observación crítica registrada.
    A continuación, los detalles del proyecto afectado.
</p>

<table width="100%" cellspacing="0" cellpadding="0"
       style="background:#F7F9FC; border:1px solid #E1E8F0; border-radius:10px; padding:18px;">

    <tr>
        <td style="font-size:13px; color:#0D4C9C; font-weight:700; padding-bottom:12px;">
            Información de la Anulación
        </td>
    </tr>

    <tr>
        <td>
            <table width="100%" cellpadding="0" cellspacing="0">

                <tr>
                    <td style="font-size:14px; width:160px; padding:6px 0; color:#555;"><b>Proyecto:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.ProjectName</td>
                </tr>

                <tr>
                    <td style="font-size:14px; padding:6px 0; color:#555;"><b>N° Oportunidad:</b></td>
                    <td style="font-size:14px; padding:6px 0;">@Model.OpporNum</td>
                </tr>

            </table>
        </td>
    </tr>
</table>

<br />

<p style="margin:0 0 10px; font-size:14px; font-weight:600; color:#0D4C9C;">
    Motivo de la Anulación
</p>

<table width="100%" cellspacing="0" cellpadding="0"
       style="border-collapse:collapse; font-size:13px; margin-bottom:8px;">
    <thead>
        <tr>
            <th align="left" style="padding:8px; border-bottom:1px solid #E1E8F0; color:#555;">Descripción de la Observación</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td style="padding:15px 8px; border-bottom:1px solid #F0F3F7; line-height:1.5; color:#333;">
                @Model.Message
            </td>
        </tr>
    </tbody>
</table>

<p style="margin:25px 0 0; font-size:14px; line-height:1.6; color:#444;">
    Para continuar con el flujo, será necesario subsanar la observación y generar una <b>nueva versión</b> de la cotización en el sistema.
</p>